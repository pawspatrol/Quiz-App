<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quiz App</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: #fff;
      margin: 0;
      padding: 0;
    }

    header {
      background: #1e293b;
      padding: 15px;
      text-align: center;
      font-size: 20px;
      font-weight: bold;
    }

    #timer {
      text-align: center;
      margin: 10px;
      font-size: 18px;
      color: #facc15;
    }

    #quiz-container {
      padding: 20px;
    }

    .question-box {
      margin-bottom: 20px;
      padding: 15px;
      background: #1e293b;
      border-radius: 10px;
    }

    button {
      padding: 10px 15px;
      margin: 5px;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      background: #22c55e;
      color: white;
    }

    #navigator {
      display: flex;
      flex-wrap: wrap;
      padding: 10px;
      background: #020617;
    }

    .nav-btn {
      width: 35px;
      height: 35px;
      margin: 3px;
      background: #334155;
      color: white;
      border-radius: 5px;
      text-align: center;
      line-height: 35px;
      cursor: pointer;
    }

    .answered {
      background: #22c55e;
    }

    .current {
      background: #facc15;
      color: black;
    }

    #results-container {
      display: none;
      padding: 20px;
    }

    .correct {
      color: #22c55e;
    }

    .wrong {
      color: #ef4444;
    }
  </style>
</head>

<body>

<header>📖 Quiz Platform</header>

<div id="timer">⏱ Time Left: 20:00</div>

<!-- NAVIGATION -->
<div id="navigator"></div>

<!-- QUIZ -->
<div id="quiz-container"></div>

<div style="text-align:center;">
  <button onclick="submitQuiz()">Submit Quiz</button>
</div>

<!-- RESULTS -->
<div id="results-container">
  <h2 id="score"></h2>
  <h3 id="percentage"></h3>
  <div id="review"></div>
</div>

<!-- BACKGROUND MUSIC -->
<audio id="bg-music" loop>
  <source src="baruch.mp3" type="audio/mpeg">
</audio>

<script>
  // Auto-play attempt (user interaction required in some browsers)
  document.body.addEventListener("click", () => {
    document.getElementById("bg-music").play();
  }, { once: true });
</script>

<!-- SCRIPTS -->
<script src="script.js"></script>
<script src="engine.js"></script>

</body>
</html>
